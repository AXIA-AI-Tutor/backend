# Profile
SPRING_PROFILES_ACTIVE=local

# Database
POSTGRES_DB=avatar_coach
POSTGRES_USER=avatar
POSTGRES_PASSWORD=your-local-password

DB_URL=jdbc:postgresql://localhost:5432/avatar_coach
DB_USERNAME=avatar
DB_PASSWORD=your-local-password

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
OAUTH2_SUCCESS_REDIRECT_URL=http://localhost:3000

# AI Server
AI_SERVER_BASE_URL=http://localhost:8000

# Internal API
INTERNAL_API_KEY=your-internal-api-key

# Google Cloud Storage (default: disabled)
GCS_STORAGE_ENABLED=false
GCS_BUCKET_NAME=avatar-coach-gcs-bucket
GCS_DOCUMENT_PREFIX=documents
GCS_SIGNED_URL_EXPIRATION_MINUTES=10
GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account.json

# Cloud Run runtime
PORT=8080
